# ============================================================================
# Ant-RH .gitignore
# Python + FastAPI + Next.js dashboard, heavy `runs/` artifacts, local models.
# ============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.so
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
.env
.env.*

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ---------------------------------------------------------------------------
# Logs & runtime
# ---------------------------------------------------------------------------
*.log
logs/
tmp/
temp/

# ---------------------------------------------------------------------------
# Runs (CRITICAL)
# ---------------------------------------------------------------------------
runs/*
!runs/.gitkeep
!runs/README.md

# optionally allow small summaries
!runs/*_summary.json
!runs/*_report.md

# ---------------------------------------------------------------------------
# Models (CRITICAL)
# ---------------------------------------------------------------------------
*.gguf
*.pt
*.pth
*.ckpt
models/
checkpoints/

# ---------------------------------------------------------------------------
# Data
# ---------------------------------------------------------------------------
*.csv
*.parquet
*.npy
*.npz
*.h5

# keep small configs if needed
!*.config.json

# ---------------------------------------------------------------------------
# Figures / outputs
# ---------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.pdf
*.svg

figures/
plots/
outputs/

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------
web/node_modules/
web/.next/
web/out/
web/.env*

# ---------------------------------------------------------------------------
# API / temp files
# ---------------------------------------------------------------------------
runs/dashboard_port.txt

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# Safety
# ---------------------------------------------------------------------------
# prevent accidental huge commits
*.zip
*.tar
*.tar.gz
*.7z

